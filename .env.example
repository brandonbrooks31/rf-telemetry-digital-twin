# RF Telemetry Digital Twin — Environment Variables
# Copy this file to .env for local development
# NEVER commit .env to version control

# ── Google / Genkit ────────────────────────────────────────────────────────
# Gemini API key (for AI-enhanced anomaly explanation; optional for scoring)
GOOGLE_GENAI_API_KEY=your-gemini-api-key-here

# GCP Project ID (used by firebase-admin ADC and Cloud Run)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Firebase / Firestore ───────────────────────────────────────────────────
# Service account key path (local dev only; not needed on Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: use Firestore emulator locally
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
