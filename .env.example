# RF Telemetry Digital Twin — Environment Variables
# Copy this file to .env for local development
# NEVER commit .env to version control

# ── Google / Genkit ────────────────────────────────────────────────────────
# Gemini API key (for AI-enhanced anomaly explanation; optional for scoring)
GOOGLE_GENAI_API_KEY=your-gemini-api-key-here

# GCP Project ID (used by firebase-admin ADC and Cloud Run)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Firebase / Firestore ───────────────────────────────────────────────────
# Service account key path (local dev only; not needed on Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: use Firestore emulator locally
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Cloud Run / OIDC (set when deployed) ───────────────────────────────────
# CLOUD_RUN_URL=https://rf-telemetry-digital-twin-xxxx-uc.a.run.app

# ── ERP Webhook (Pitch Demo) ───────────────────────────────────────────────
# URL of the mock ERP work-order service (local or Cloud Run)
ERP_WEBHOOK_URL=http://localhost:9090/work-orders
# Port for the mock ERP service when running locally
ERP_PORT=9090

# ── RF Edge Simulator ──────────────────────────────────────────────────────
# Telemetry endpoint the simulator posts to
TELEMETRY_URL=http://localhost:8080/telemetry
# Optional: override the simulated device ID
# SESSION_ID=HW-TRANSPONDER-001
# Optional: override step interval in ms (default 1500)
# STEP_INTERVAL=1500
